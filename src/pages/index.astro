---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import SobreNosotrosSection from '../components/SobreNosotrosSection.astro';
import CategoriasSection from '../components/CategoriasSection.astro';
import DegustacionSection from '../components/DegustacionSection.astro';
import GaleriaSection from '../components/GaleriaSection.astro';
import UbicacionSection from '../components/UbicacionSection.astro';
import ContactoSection from '../components/ContactoSection.astro';
import MapaSection from '../components/MapaSection.astro';
import FooterSection from '../components/FooterSection.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <HeroSection />
    <SobreNosotrosSection />
    <GaleriaSection />
    <CategoriasSection />
    <DegustacionSection />
    <UbicacionSection />
    <ContactoSection />
  </main>
  <MapaSection />
  <FooterSection />

  <script>
    import('../scripts/scroll-animations');
  </script>
</BaseLayout>
