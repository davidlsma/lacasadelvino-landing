---
---

<section
  id="galeria"
  class="relative flex items-center justify-center overflow-hidden"
  style="min-height: 65vh"
>
  <!-- Imagen full-bleed -->
  <img
    src="/assets/images/frase-bg.png"
    alt="Cava de La Casa del Vino San Juan"
    loading="lazy"
    width="1080"
    height="1350"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />
  <!-- Overlay oscuro -->
  <div
    class="absolute inset-0"
    style="background: rgba(12,12,12,0.72)"
  ></div>

  <!-- Cita centrada -->
  <div class="relative z-10 px-6 py-24 text-center max-w-3xl mx-auto fade-in">
    <div class="w-16 h-px mx-auto" style="background-color: #722F37; margin-bottom: 3rem;"></div>
    <blockquote>
      <p
        class="heading-lg font-bold italic leading-snug"
        style="font-family: 'Playfair Display', Georgia, serif; color: var(--color-on-surface); margin-bottom: 3rem;"
      >
        "Cada botella cuenta una historia.<br />La tuya empieza acá."
      </p>
    </blockquote>
    <p class="text-xs uppercase tracking-widest" style="color: #722F37; margin-bottom: 3rem;">
      — La Casa del Vino, San Juan
    </p>
    <div class="w-16 h-px mx-auto" style="background-color: #722F37;"></div>
  </div>
</section>
