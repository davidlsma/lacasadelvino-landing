---
const whatsappUrl  = 'https://api.whatsapp.com/message/6U2X4KNSLDISO1?autoload=1&app_absent=0';
const instagramUrl = 'https://instagram.com/lacasadelvinosanjuan';
---

<section
  id="contacto"
  class="section-py relative"
  style="background-color: var(--color-surface);"
>
  <div class="absolute top-0 left-0 right-0 h-px" style="background-color: var(--color-surface-high)"></div>
  <div class="container">
  <div style="max-width: 40rem; margin-inline: auto; text-align: center">
    <h2
      class="contacto-heading font-bold fade-in"
      style="text-transform: uppercase; color: #fff; margin-bottom: 3rem;"
    >
      ¿No sabés qué elegir?
    </h2>

    <p class="body-lg mb-12 leading-relaxed fade-in" style="color: rgba(240,235,227,0.7)">
      Contanos la ocasión y te ayudamos a encontrar el vino o la bebida perfecta. Eso es lo que nos gusta hacer.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center fade-in" style="margin-top: 2rem;">
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary contacto-btn" style="background-color: #722F37;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escribinos por WhatsApp
      </a>
      <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="btn-primary contacto-btn" style="background-color: #722F37;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Seguinos en Instagram
      </a>
    </div>

  </div>
  </div>
</section>

<style>
  .contacto-heading {
    font-size: clamp(1.6rem, 3.5vw, 3.5rem);
    font-family: 'Playfair Display', Georgia, serif;
  }

  .contacto-btn {
    font-size: 0.875rem;
    padding: 0.875rem 1.75rem;
  }
  .contacto-btn:hover {
    background-color: #5a2229 !important;
  }
</style>
