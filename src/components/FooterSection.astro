---
const year          = new Date().getFullYear();
const instagramUrl  = 'https://instagram.com/lacasadelvinosanjuan';
const whatsappUrl   = 'https://wa.me/5492645620073';
---

<footer
  style="background-color: var(--color-surface); border-top: 1px solid var(--color-surface-high); padding-top: 3rem; padding-bottom: 3rem;"
>
  <div class="container">

    <div class="grid grid-cols-2 gap-8 mb-10">

      <!-- Columna izquierda: logo -->
      <div class="flex items-start" style="padding-top: 2rem; padding-bottom: 2rem;">
        <a href="/" aria-label="La Casa del Vino — Inicio">
          <img
            src="assets/images/logo.jpg"
            alt="La Casa del Vino"
            width="60"
            height="60"
            class="footer-logo"
          />
        </a>
      </div>

      <!-- Columna derecha: navegación -->
      <nav aria-label="Pie de página">
        <p class="footer-nav-title">Navegación</p>
        <ul class="flex flex-col gap-3 list-none">
          <li>
            <a href="#sobre-nosotros" class="footer-link">Nosotros</a>
          </li>
          <li>
            <a href="#categorias" class="footer-link">Productos</a>
          </li>
          <li>
            <a href="#degustacion" class="footer-link">Degustación</a>
          </li>
          <li>
            <a href="#ubicacion" class="footer-link">Ubicación</a>
          </li>
          <li>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="footer-link">Instagram</a>
          </li>
          <li>
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="footer-link">WhatsApp</a>
          </li>
        </ul>
      </nav>

    </div>

    <div style="border-top: 1px solid var(--color-surface-high); padding-top: 2rem; margin-top: 2rem; text-align: center;">
      <p class="text-xs" style="color: var(--color-surface-high)">
        © {year} La Casa del Vino San Juan. Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-logo {
    mix-blend-mode: screen;
    width: 160px;
    height: auto;
    display: block;
    opacity: 0.85;
  }

  .footer-nav-title {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #722F37;
    margin-bottom: 1rem;
  }

  .footer-link {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-on-surface-muted);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .footer-link:hover {
    opacity: 0.5;
  }
</style>
