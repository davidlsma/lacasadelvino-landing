---
const whatsappUrl = 'https://wa.me/5492645620073?text=Hola!%20Quiero%20reservar%20una%20degustaci%C3%B3n%20en%20la%20cava.';

const detalles = [
  {
    titulo: 'Guiada por expertos',
    descripcion: 'Nuestros especialistas te llevan por una selección de vinos curada, explicando cada etiqueta, bodega y varietal.',
  },
  {
    titulo: 'Maridaje incluido',
    descripcion: 'Cada degustación viene acompañada de una tabla de quesos y fiambres seleccionados para realzar los aromas y sabores.',
  },
  {
    titulo: 'Grupos & Privadas',
    descripcion: 'Desde una salida en pareja hasta un evento corporativo. Personalizamos la experiencia según el grupo y la ocasión.',
  },
  {
    titulo: 'En nuestra vinoteca',
    descripcion: 'El ambiente de la vinoteca suma: temperatura ideal, iluminación pensada y la tranquilidad para disfrutar sin apuros.',
  },
];
---

<section
  id="degustacion"
  class="section-py relative overflow-hidden"
  style="background-color: var(--color-surface-low)"
>
  <!-- Franja de acento superior -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background-color: var(--color-surface-high)"></div>

  <div class="container">

    <!-- Título centrado -->
    <div class="text-center fade-in" style="margin-bottom: 4rem;">
      <h2
        class="degu-heading font-bold leading-tight"
        style="text-transform: uppercase;"
      >
        Servicio de Degustación.
      </h2>
    </div>

    <!-- Cards de detalles -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 fade-in" style="margin-bottom: 4rem;">
      {detalles.map(item => (
        <div
          class="degu-card flex flex-col gap-4 items-center text-center"
          style="background-color: var(--color-surface); border: 1px solid var(--color-surface-high); padding: 2rem 2.5rem"
        >
          <div class="w-8 h-px mb-1" style="background-color: #722F37"></div>
          <h3
            class="font-semibold text-lg"
            style="font-family: 'Playfair Display', Georgia, serif; color: var(--color-on-surface)"
          >
            {item.titulo}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-on-surface-muted)">
            {item.descripcion}
          </p>
        </div>
      ))}
    </div>

    <!-- Fila 2: Imagen a ancho completo -->
    <div class="overflow-hidden fade-in" style="margin-bottom: 4rem;">
      <img
        src="/assets/images/lifestyle-degustacion-nueva.png"
        alt="Degustación de vinos en la cava de La Casa del Vino"
        loading="lazy"
        width="1600"
        height="700"
        class="w-full object-cover object-center img-hover"
        style="height: clamp(240px, 35vw, 480px)"
      />
    </div>

    <!-- CTA central -->
    <div class="fade-in flex justify-center pt-16">
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary" style="white-space: nowrap; background-color: #722F37;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Reservá tu lugar hoy
      </a>
    </div>

  </div>

  <!-- Franja de acento inferior -->
  <div class="absolute bottom-0 left-0 right-0 h-px" style="background-color: var(--color-surface-high)"></div>
</section>

<style>
  .degu-heading {
    font-size: clamp(1.6rem, 3.5vw, 3.5rem);
    font-family: 'Playfair Display', Georgia, serif;
  }

  #degustacion .btn-primary:hover {
    background-color: #5a2229 !important;
  }

  .degu-card {
    transition: background-color 0.2s ease;
  }
  .degu-card:hover {
    background-color: var(--color-surface-low) !important;
  }
</style>
